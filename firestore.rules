rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Landing Page: Allow anyone to create a waitlist entry
    match /waitlist/{documentId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Allow anyone to store pending emails if sending fails
    match /waitlist_pending_emails/{documentId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // Landing Page: Allow anyone to update the global counter
    match /stats/{documentId} {
      allow get: if true;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // Default rule for ALL other collections (protecting your other apps)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
